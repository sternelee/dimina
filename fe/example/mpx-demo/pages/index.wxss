.page{box-sizing:border-box;min-height:100vh;padding:40rpx 32rpx 64rpx}.hero{background:linear-gradient(135deg,#182848,#315b8a);border-radius:28rpx;box-shadow:0 20rpx 40rpx rgba(24,40,72,.18);color:#fff;padding:44rpx 36rpx}.hero__badge{color:#a9d7ff;font-size:22rpx;font-weight:600;letter-spacing:4rpx}.hero__title{font-size:46rpx;font-weight:700;margin-top:18rpx}.hero__description{color:#d8e8f8;font-size:27rpx;line-height:1.65;margin-top:18rpx}.panel{background:#fff;border:1rpx solid #dce5f2;border-radius:24rpx;margin-top:28rpx;padding:32rpx}.panel__label{color:#53729f;font-size:24rpx}.panel__value{font-size:38rpx;font-weight:600;margin-top:12rpx}.counter{color:#5d6c82;font-size:28rpx;margin:20rpx 0}.primary-button,.secondary-button{border-radius:16rpx;font-size:28rpx;line-height:80rpx}.primary-button{background:#315b8a;color:#fff}.secondary-button{background:#f6f9fd;border:1rpx solid #b8c9de;color:#315b8a;margin-top:20rpx}.deferred-result{background:#eaf7ee;border-radius:14rpx;color:#256b3d;font-size:27rpx;margin-top:22rpx;padding:22rpx}